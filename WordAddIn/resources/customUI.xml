<?xml version="1.0" encoding="utf-8" ?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui"
          onLoad="OnLoad">
	<ribbon>
		<officeMenu>
			<menu id="SaveAsDaisyOfficeMenu"
			      getLabel="GetRibbonLabel"
			      insertAfterMso="FileSaveAsMenu"
			      itemSize="large"
			      getImage="IconSelector">
				<button id="ExportToXMLOfficeButton"
				        getLabel="GetRibbonLabel"
				        onAction="SaveAsDTBookXML"
				        getEnabled="RibbonButtonsEnabled"
				        getImage="IconSelector"
				        getScreentip="GetRibbonDescription"
				        getDescription="GetRibbonDescription"/>
				<button id="ExportToDaisy3OfficeButton"
				        getLabel="GetRibbonLabel"
				        onAction="SaveAsDAISY3"
				        getEnabled="RibbonButtonsEnabled"
				        getImage="IconSelector"
				        getDescription="GetRibbonDescription"
				        getScreentip="GetRibbonDescription"/>
				<button id="ExportToEpub3OfficeButton"
				        getLabel="GetRibbonLabel"
				        onAction="SaveAsEPUB3"
				        getEnabled="RibbonButtonsEnabled"
				        getImage="IconSelector"
				        getDescription="GetRibbonDescription"
				        getScreentip="GetRibbonDescription"/>
				<button id="ExportToMP3OfficeButton"
				        getLabel="GetRibbonLabel"
				        onAction="SaveAsMP3"
				        getEnabled="RibbonButtonsEnabled"
				        getImage="IconSelector"
				        getDescription="GetRibbonDescription"
				        getScreentip="GetRibbonDescription"/>
				<button id="ExportToDaisy202OfficeButton"
				        getLabel="GetRibbonLabel"
				        onAction="SaveAsDaisy202"
				        getEnabled="RibbonButtonsEnabled"
				        getImage="IconSelector"
				        getDescription="GetRibbonDescription"
				        getScreentip="GetRibbonDescription"/>
			</menu>
		</officeMenu>
		<tabs>
			<tab id="SaveAsDAISYTab"
			     getLabel="GetRibbonLabel">
				<group id="ExportGroup"
				       getLabel="GetRibbonLabel">
					<menu id="ExportTabMenu"
					      getLabel="GetRibbonLabel"
					      size="large"
					      getImage="IconSelector">
						<button id="ExportToXMLTabButton"
						        getLabel="GetRibbonLabel"
						        onAction="SaveAsDTBookXML"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getScreentip="GetRibbonDescription"
						        getDescription="GetRibbonDescription"/>
						<button id="ExportToDaisy3TabButton"
						        getLabel="GetRibbonLabel"
						        onAction="SaveAsDAISY3"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
						<button id="ExportToEpub3TabButton"
						        getLabel="GetRibbonLabel"
						        onAction="SaveAsEPUB3"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
						<button id="ExportToMP3TabButton"
						        getLabel="GetRibbonLabel"
						        onAction="SaveAsMP3"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
						<button id="ExportToDaisy202TabButton"
						        getLabel="GetRibbonLabel"
						        onAction="SaveAsDaisy202"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
					</menu> 
					<menu id="ImportTabMenu"
					      getLabel="GetRibbonLabel"
					      size="large"
					      getImage="IconSelector">
						<button id="ImportODTTabButton"
						        getLabel="GetRibbonLabel"
						        onAction="ImportODT"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
						<button id="ImportRTFTabButton"
						        getLabel="GetRibbonLabel"
						        onAction="ImportRTF"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
						<button id="ImportPDFTabButton"
						        getLabel="GetRibbonLabel"
						        onAction="ImportPDF"
						        getEnabled="RibbonButtonsEnabled"
						        getImage="IconSelector"
						        getDescription="GetRibbonDescription"
						        getScreentip="GetRibbonDescription"/>
					</menu>
				</group>
				<group id="AbbreviationsGroup"
				       getLabel="GetRibbonLabel">
					<button id="MarkAbbreviationTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="MarkAsAbbreviationUI"
					        getImage="IconSelector"
					        getEnabled="RibbonButtonsEnabled"/>
					<button id="ManageAbbreviationsTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="ManageAbbreviation"
					        getImage="IconSelector"
					        getEnabled="RibbonButtonsEnabled"/>
				</group>
				<group id="AcronymsGroup"
				       getLabel="GetRibbonLabel">
					<button id="MarkAcronymTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="MarkAsAcronymUI"
					        getImage="IconSelector"
					        getEnabled="RibbonButtonsEnabled"/>
					<button id="ManageAcronymsTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="ManageAcronym"
					        getImage="IconSelector"
					        getEnabled="RibbonButtonsEnabled"/>
				</group>
				<group id="DaisyStylesGroup"
				       getLabel="GetRibbonLabel">
					<button id="ImportDaisyStylesTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="Update_Styles"
					        getEnabled="GetEnabled"
					        getImage="IconSelector"/>
				</group>
				<group id="LanguageGroup"
				       getLabel="GetRibbonLabel">
					<button id="DocumentLanguageTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="GetlanguageSettings"
					        getImage="IconSelector"
					        getEnabled="RibbonButtonsEnabled"/>
				</group>
				<group id="MetadataGroup"
					   getLabel="GetRibbonLabel">
					<button id="DocumentMetadataTabButton"
							getLabel="GetRibbonLabel"
							size="large"
							onAction="DocumentMetadataUI"
							getImage="IconSelector"/>
				</group>
				<group id="SettingsGroup"
				       getLabel="GetRibbonLabel">
					<button id="SettingsTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="GetDaisySettings"
					        getImage="IconSelector"/>
				</group>
				<group id="HelpGroup"
				       getLabel="GetRibbonLabel">
					<button id="VersionDetailsTabButton"
					        getLabel="GetRibbonLabel"
					        size="large"
					        onAction="AboutUI"
					        getImage="IconSelector"/>
					<menu id="DocumentationTabMenu"
					      getLabel="GetRibbonLabel"
					      size="large"
					      getImage="IconSelector">
						<button id="OpenManualTabButton"
						        getLabel="GetRibbonLabel"
						        onAction="ShowWordManual"/>
						<button id="OpenGuidelinesTabButton"
						        getLabel="GetRibbonLabel"
						        onAction="ShowAuthoringGuidelines"/>
					</menu>
				</group>
			</tab>
		</tabs>
	</ribbon>
</customUI>