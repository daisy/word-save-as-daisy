<Window x:Class="Daisy.SaveAsDAISY.WPF.ConversionProgress"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Daisy.SaveAsDAISY.WPF"
        mc:Ignorable="d"
        Title="Progression"
        Width="450"
        SizeToContent="Height"
        Closing="Window_Closing">
    <DockPanel Height="Auto" VerticalAlignment="Stretch">
        <StackPanel DockPanel.Dock="Top">
            <ProgressBar x:Name="ProgressionTracker"
                         Height="20"
                         Margin="5,5,5,0"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         IsIndeterminate="False" />


            <TextBox x:Name="CurrentAction"
                     Margin="5,5,5,0"
                     Text=""
                     AutomationProperties.Name="Progress"
                     AutomationProperties.HelpText=""
                     AutomationProperties.LiveSetting="Assertive"
                     IsReadOnly="True" />
        </StackPanel>

        <Expander
                  Header="Details"
                  ExpandDirection="Down"
                  IsExpanded="True"
                  BorderThickness="1"
                  BorderBrush="Black"
                  Margin="5,5,5,0"
                  DockPanel.Dock="Top" Height="300" >
            <Grid>
                <TextBox TextWrapping="Wrap"
                         MinHeight="200"
                         Margin="5"
                         x:Name="MessageTextArea"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True" />
            </Grid>
        </Expander>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    DockPanel.Dock="Bottom">
            <Button Width="61"
                    Margin="5"
                    Click="CancelButton_Click"
                    x:Name="CancelButton">Cancel</Button>
            <Button Width="61"
                    Margin="5"
                    Click="CloseButton_Click">Close</Button>
        </StackPanel>
    </DockPanel>
</Window>
