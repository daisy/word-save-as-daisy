<Window x:Class="Daisy.SaveAsDAISY.WPF.Pipeline2Properties"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Daisy.SaveAsDAISY.WPF"
        mc:Ignorable="d"
        Title="DAISY Pipeline 2 - Available properties" Height="450" Width="800">
    <StackPanel>
        <!--<TextBlock Text="The following properties are available in the DAISY Pipeline 2:" Margin="10" FontSize="11" FontWeight="Bold"/>-->
        <ListBox ItemsSource="{Binding Properties}" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Value}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Window>
